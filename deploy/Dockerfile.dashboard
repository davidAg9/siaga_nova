# SIAGA dashboard image. Build context is the siaga/ directory:
#   docker build -f deploy/Dockerfile.dashboard -t siaga-dashboard .
FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY dashboard/ ./dashboard/
COPY models/ ./models/
COPY data/clean/ ./data/clean/
ENV SIAGA_API=http://api:8080
EXPOSE 8501
CMD ["streamlit", "run", "dashboard/app.py", "--server.port=8501", "--server.address=0.0.0.0", "--server.headless=true"]
